{
  "version": 2,
  "builds": [
    {
      "src": "api/anomaly.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "login.html",
      "use": "@vercel/static"
    },
    {
      "src": "signup.html",
      "use": "@vercel/static"
    },
    {
      "src": "dashboard.html",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    },
    {
      "src": "dashboard.js",
      "use": "@vercel/static"
    },
    {
      "src": "firebase.js",
      "use": "@vercel/static"
    },
    {
      "src": "auth.js",
      "use": "@vercel/static"
    },
    {
      "src": "anomelydetection.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/anomaly",
      "dest": "/api/anomaly.js"
    },
    {
      "src": "/api/trending",
      "dest": "/api/anomaly.js"
    },
    {
      "src": "/dashboard",
      "dest": "/dashboard.html"
    },
    {
      "src": "/login",
      "dest": "/login.html"
    },
    {
      "src": "/signup",
      "dest": "/signup.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
